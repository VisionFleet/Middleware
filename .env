# Firebase
FIREBASE_CREDENTIAL_PATH=configs/serviceAccountKey.json
FIREBASE_DATABASE_URL=https://fleet-313a7-default-rtdb.asia-southeast1.firebasedatabase.app/
FIREBASE_WRITE_ENABLED=false
LOAD_MAP_FROM_FIREBASE=true
MAP_FIREBASE_WRITE_MODE=replace

# MQTT
# MQTT_BROKER_HOST_TEMP takes precedence when it is non-empty, for compatibility
# with the AGV notebook. Remove/comment it when the temporary network is not used.
MQTT_BROKER_HOST=10.78.144.196
MQTT_BROKER_HOST_TEMP=
MQTT_BROKER_PORT=1883
MQTT_KEEPALIVE_SEC=30
MQTT_CLIENT_ID_PREFIX=agv_middleware
MQTT_STATUS_QOS=0
MQTT_CONTROL_QOS=0
MQTT_ROUTE_QOS=0

# AGV logical ID <-> MQTT topic ID
AGV1_MQTT_TOPIC_ID=AGV_01
AGV2_MQTT_TOPIC_ID=AGV_02

# Map publication
LAYOUT_ID=five_node_dynamic_reroute_v1
MAP_VERSION=2
PUBLISH_MAP_ON_CONNECT=true
MAP_SNAPSHOT_RETAIN=true

# Mission policy
AUTO_START_ENABLED=true
REQUIRE_ALL_ROBOT_STATUS_BEFORE_AUTOSTART=false
DEFAULT_CONTROL_SPEED=0.30

# Current AGV protocol: do not change these to resume/recovery_reroute.
LINE_STOP_COMMAND=line_stop
LINE_START_COMMAND=line_start
REQUIRE_FRESH_STOP_CONFIRMATION=true

# ACK/status state-machine timeouts
STOP_CONFIRM_TIMEOUT_SEC=3.0
ROUTE_ACK_TIMEOUT_SEC=3.0
START_CONFIRM_TIMEOUT_SEC=3.0
MAX_CONTROL_RETRIES=2
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SEC=0.25
# Keep this comfortably above the AGV STATUS_INTERVAL (normally 2-3 periods + network margin).
STATUS_STALE_SEC=5.0
# Legacy compatibility only: the revised middleware does not auto-release occupancy by TTL.
OCCUPANCY_HOLD_SEC=30.0
WAITING_PATH_RETRY_SEC=1.0

# Dynamic routing policy
CAUTION_COST_MULTIPLIER=3.0
REPLAN_MOVING_ON_OCCUPANCY_CHANGE=true
REPLAN_ON_EDGE_OPEN=false

REQUIRE_GOAL_IN_STATUS=false